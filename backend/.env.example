# =============================================================================
# GR-ATTITUDE Backend Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in your actual values.
# For Render deployment, configure these in the Dashboard → Environment.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3001

# -----------------------------------------------------------------------------
# Database — Option 1: Render Postgres (recommended for production)
# -----------------------------------------------------------------------------
# Render provides DATABASE_URL automatically when you add a PostgreSQL database.
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@hostname.render.com:5432/dbname

# -----------------------------------------------------------------------------
# Database — Option 2: Manual Postgres Config (if not using DATABASE_URL)
# -----------------------------------------------------------------------------
# Uncomment and configure if you want to override Render's DATABASE_URL
# DB_TYPE=postgres
# DB_HOST=hostname.render.com
# DB_PORT=5432
# DB_USERNAME=user
# DB_PASSWORD=password
# DB_DATABASE=dbname

# -----------------------------------------------------------------------------
# Database — Option 3: SQLite (local development only)
# -----------------------------------------------------------------------------
# DB_TYPE=sqlite
# (No other config needed — creates `gr_attitude.sqlite` in project root)

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Generate a secure secret with: openssl rand -base64 32
JWT_SECRET=YOUR_SECURE_JWT_SECRET_HERE
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# CORS — Allowed Frontend Origins
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGIN=https://gr-attitude.onrender.com,https://yourdomain.com

# -----------------------------------------------------------------------------
# Frontend URL — For OAuth Redirects
# -----------------------------------------------------------------------------
# The frontend URL that OAuth flows redirect to after login
FRONTEND_URL=https://gr-attitude.onrender.com

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
# Get credentials from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID
# 2. Authorized redirect URIs: https://your-backend.onrender.com/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_CALLBACK_URL=https://gr-attitude-api.onrender.com/auth/google/callback

# -----------------------------------------------------------------------------
# Facebook OAuth
# -----------------------------------------------------------------------------
# Get credentials from: https://developers.facebook.com/apps
# 1. Create Facebook App
# 2. Add "Facebook Login" product
# 3. Valid OAuth Redirect URIs: https://your-backend.onrender.com/auth/facebook/callback
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=https://gr-attitude-api.onrender.com/auth/facebook/callback

# -----------------------------------------------------------------------------
# Redis (Optional — For Rate Limiting / Caching)
# -----------------------------------------------------------------------------
# If using Render Redis add-on, uncomment and configure:
# REDIS_HOST=your-redis-hostname.render.com
# REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Seeds (Optional — Development Only)
# -----------------------------------------------------------------------------
# Default password for seeded test users (not for production)
# SEED_PASSWORD=TestPassword123!
